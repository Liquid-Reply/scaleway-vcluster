# ClusterMAX-Aligned Configuration Example
# Copy this file and customize for your environment:
#   cp clustermax-enabled.tfvars.example clustermax.tfvars
#   vim clustermax.tfvars
#   terraform apply -var-file="clustermax.tfvars"

# Project Configuration
project_id = "your-project-id"  # Found at console.scaleway.com/project/settings

# Basic Cluster Configuration
cluster_name = "my-ai-cluster"
region       = "fr-par"
zone         = "fr-par-1"       # L4 and H100 GPUs available here
k8s_version  = "1.34"
cni          = "cilium"

# Standard Node Pool
node_type           = "GP1-M"
node_count          = 3
min_nodes           = 2
max_nodes           = 10
autoscaling_enabled = true
autohealing_enabled = true

# GPU Node Pool
# Available types in fr-par-1: L4-1-24G (NVIDIA L4 24GB), H100-1-80G (NVIDIA H100 80GB)
# Scaleway auto-installs the NVIDIA GPU operator — no manual setup needed.
gpu_pool_enabled        = true
gpu_node_type           = "L4-1-24G"
gpu_node_count          = 1
gpu_min_nodes           = 0
gpu_max_nodes           = 5
gpu_autoscaling_enabled = true
gpu_autohealing_enabled = true

# VCluster Fleet — Per-Tenant Multi-Tenancy (ClusterMAX requirement)
# Add one entry per team/tenant. Each gets an isolated virtual K8s cluster.
vclusters = {
  "team-ml" = {
    cpu_limit                   = "2000m"
    memory_limit                = "4Gi"
    storage_size                = "10Gi"
    storage_class               = "scw-bssd"
    isolation_enabled           = true
    resource_quota_cpu          = "20"
    resource_quota_memory       = "40Gi"
    resource_quota_cpu_limit    = "30"
    resource_quota_memory_limit = "60Gi"
  }
  "team-dev" = {
    cpu_limit                   = "1000m"
    memory_limit                = "2Gi"
    storage_size                = "5Gi"
    storage_class               = "scw-bssd"
    isolation_enabled           = true
    resource_quota_cpu          = "10"
    resource_quota_memory       = "20Gi"
    resource_quota_cpu_limit    = "15"
    resource_quota_memory_limit = "30Gi"
  }
}

# Tags
tags = [
  "environment:production",
  "workload:ai-ml",
  "clustermax:enabled",
  "managed-by:terraform"
]

# Resource Cleanup
delete_additional_resources = false  # Set to true only in dev/test
